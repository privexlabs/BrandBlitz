# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://brandblitz:brandblitz_dev@localhost:5432/brandblitz
POSTGRES_PASSWORD=brandblitz_dev

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_in_production
NEXTAUTH_SECRET=change_me_in_production
NEXTAUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── Stellar ──────────────────────────────────────────────────────────────────
# testnet | public
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# The hot wallet that holds USDC and sends payouts
STELLAR_HOT_WALLET_SECRET=your_stellar_secret_key_here
# Testnet USDC issuer (Centre)
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# ─── Storage (MinIO in dev / R2 or S3 in prod) ────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=brandblitz
S3_SECRET_ACCESS_KEY=brandblitz123
S3_BUCKET=brandblitz-assets
S3_PUBLIC_URL=http://localhost:9000/brandblitz-assets
S3_FORCE_PATH_STYLE=true

# ─── MinIO (dev only) ─────────────────────────────────────────────────────────
MINIO_ROOT_USER=brandblitz
MINIO_ROOT_PASSWORD=brandblitz123

# ─── Twilio Verify (phone verification) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PHONE_HASH_SALT=replace_with_a_random_32_byte_secret

# ─── Webhooks ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=change_me_in_production

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api

# ─── Domain (prod only) ───────────────────────────────────────────────────────
# DOMAIN=brandblitz.app
