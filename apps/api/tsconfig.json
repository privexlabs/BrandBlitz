{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@brandblitz/stellar": ["../../packages/stellar/src/index.ts"],
      "@brandblitz/storage": ["../../packages/storage/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
