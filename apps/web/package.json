{
  "name": "@brandblitz/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "analyze": "ANALYZE=true NEXT_PUBLIC_API_URL=http://localhost/api next build --webpack",
    "start": "next start",
    "a11y": "playwright test -c ../../e2e/playwright.config.ts a11y",
    "lint": "next lint",
    "knip": "knip",
    "type-check": "tsc --noEmit",
    "test": "corepack pnpm exec vitest run",
    "test:coverage": "corepack pnpm exec vitest run --coverage"
  },
  "dependencies": {
    "@auth/core": "0.34.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "1.1.4",
    "@radix-ui/react-slot": "1.2.4",
    "@sentry/nextjs": "^10.55.0",
    "axios": "1.14.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "decimal.js": "10.4.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.1",
    "next-auth": "4.24.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.2",
    "autoprefixer": "10.4.27",
    "eslint": "10.1.0",
    "eslint-config-next": "16.2.6",
    "fast-check": "4.8.0",
    "jsdom": "^29.0.2",
    "knip": "^5.70.1",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.6.12",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "knip": {
    "eslint": false,
    "include": [
      "files"
    ],
    "ignore": [
      "eslint.config.mjs",
      "sentry.*.config.ts",
      "vitest.setup.ts",
      "src/test/**",
      "src/**/*.test.ts",
      "src/**/*.test.tsx"
    ]
  }
}
